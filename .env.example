# Copy this file to .env and fill in the values
# Local dev: file:../data/arena.db
# Docker:    file:/data/arena.db  (set in docker-compose.yml)
DATABASE_URL=file:../data/arena.db
JWT_SECRET=change_me_to_a_long_random_string

# Worker concurrency
LLM_CONCURRENCY=15
SUBMISSION_CONCURRENCY=10

# Footer — leave blank to hide
FOOTER_COPYRIGHT=
FOOTER_ICP=

# Extra origins allowed in Next.js dev mode (comma-separated host IPs, no protocol/port)
# e.g. ALLOWED_DEV_ORIGINS=192.168.1.100,10.0.0.5
ALLOWED_DEV_ORIGINS=

# SSO — 上海交通大学 jAccount（留空则不显示该登录按钮）
JACCOUNT_CLIENT_ID=
JACCOUNT_CLIENT_SECRET=
# Must match the callback URL registered with jAccount; determines post-auth redirect host
JACCOUNT_REDIRECT_URI=https://your-domain/api/auth/sso/jaccount/callback

# SMTP email — leave blank to disable email features
# Tested with 126.com; works with any SMTP server
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@126.com
SMTP_PASS=<IMAP/SMTP service password, NOT your login password>
SMTP_FROM="LLM Arena <your-account@126.com>"

# Rate limiting — max requests per IP per time window
# Register: per hour. Login: per 15 minutes. Forgot-password: per hour.
RATE_LIMIT_REGISTER=100
RATE_LIMIT_LOGIN=60
RATE_LIMIT_FORGOT_PASSWORD=10
